## Ignore Visual Studio temporary files, build results, and files generated by popular Visual Studio add-ons.
## Original source: http://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto-generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
x64/
x86/
SDKRedirects/
bld/
[Bb]in/
[Ob]j/
[Log]s/
[Tt]est[Rr]esults/

# Visual Studio 2015/2017 cache directory
.vs/
# Uncomment if you have tasks that create to-do list files
#*.tasks

# MSTest test Results
*.trx
*.xml

# NUnit test Results
*.xml

# Bower communities
bower_components/

# Node.js
node_modules/
npm-debug.log

# VS Code folders
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/code-workspace

# JetBrains Rider
.idea/
*.sln.iml

# Docker
.dockerignore

# SQL Server
*.mdf
*.ldf
*.ndf
